# Deployed Shielded NIGHT contract address, per network.
# Fill in after deploying; copy this file to `.env`.
# The network dropdown selects which of these is used.
VITE_CONTRACT_ADDRESS_PREVIEW=
VITE_CONTRACT_ADDRESS_PREPROD=
# Optional: local devnet address (undeployed) for testing against a local stack.
VITE_CONTRACT_ADDRESS_UNDEPLOYED=

# Optional per-network override of the wrapper (wNIGHT) shielded token type,
# as it appears in the wallet's getShieldedBalances() map. Leave blank to let
# the app derive it from the contract address; set only if the derived value
# does not match your wallet's balance key.
VITE_WRAPPER_TOKEN_TYPE_PREVIEW=
VITE_WRAPPER_TOKEN_TYPE_PREPROD=
VITE_WRAPPER_TOKEN_TYPE_UNDEPLOYED=

