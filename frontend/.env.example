# Deployed Shielded NIGHT contract address, per network. Copy to `.env` and
# fill in after deploying. The network dropdown shows only networks whose
# address is set; the wNIGHT token type is derived from the address.
PREVIEW_ADDRESS=
PREPROD_ADDRESS=
MAINNET_ADDRESS=

# Optional: local devnet (docker stack) address, for development.
UNDEPLOYED_ADDRESS=
