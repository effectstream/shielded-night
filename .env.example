# SECRETS for the deploy / lock scripts. Copy to `.env` (gitignored) and fill
# in - NEVER commit `.env`. Shell environment variables take precedence over
# this file, so one-off `MN_MNEMONIC="..." bun run ...` invocations still work.
#
# Not to be confused with frontend/.env, which is committed and holds only
# public contract addresses.

# BIP-39 phrase of the deployer wallet (funded + DUST-registered), quoted:
MN_MNEMONIC=""

# Alternative to MN_MNEMONIC: raw hex seed.
MN_SEED=
